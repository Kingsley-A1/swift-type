NEXT_PUBLIC_OG_IMAGE_VERSION=2026-04-22

# Admin access
ADMIN_REGISTRATION_PASSWORD=1234567890
ADMIN_LOGIN_CODE=123456
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
