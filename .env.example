# Site URL (used for SEO and OG images in production)
NEXT_PUBLIC_SITE_URL=https://swift-type.vercel.app
# Optional: bump this value when social platforms cache an older OG image
NEXT_PUBLIC_OG_IMAGE_VERSION=2026-04-22

# Admin access
ADMIN_REGISTRATION_PASSWORD=1234567890
ADMIN_LOGIN_CODE=123456
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Auth.js
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (required for "Continue with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (required for "Continue with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
